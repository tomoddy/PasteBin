@page "{id:int}"
@model PasteBin.Pages.Pastes.ViewModel
@{
    ViewData["Title"] = $"Paste #{Model.Paste?.Id}";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Paste #@Model.Paste?.Id</h1>
    <div class="d-flex gap-2">
        <button class="btn btn-secondary" onclick="copyContent()">Copy</button>
        <a asp-page="/Pastes/Index" class="btn btn-secondary">Back</a>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <pre class="mb-0"><code>@Model.Paste?.Content</code></pre>
    </div>
</div>

<small class="text-muted mt-2 d-block">Created @Model.Paste?.CreatedAt.ToString("dd MMM yyyy HH:mm")</small>

<script>
    function copyContent() {
        navigator.clipboard.writeText(document.querySelector('code').innerText);
    }
</script>