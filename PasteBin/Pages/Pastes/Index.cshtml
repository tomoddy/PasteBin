@page
@using PasteBin.Models
@model PasteBin.Pages.Pastes.IndexModel
@{
    ViewData["Title"] = "Pastes";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Pastes</h1>
    <a asp-page="/Pastes/New" class="btn btn-secondary">New Paste</a>
</div>

@if (!Model.Pastes.Any())
{
    <p class="text-muted">No pastes yet.</p>
}
else
{
    <div class="list-group">
        @foreach (Paste paste in Model.Pastes)
        {
            <a asp-page="/Pastes/View" asp-route-id="@paste.Id" class="list-group-item list-group-item-action">
                <div class="d-flex justify-content-between">
                    <span>Paste #@paste.Id</span>
                    <small class="text-muted">@paste.CreatedAt.ToString("dd MMM yyyy HH:mm")</small>
                </div>
                <small class="text-muted">@(paste.Content?[..Math.Min(100, paste.Content.Length)] ?? "No Content")...</small>
            </a>
        }
    </div>
}