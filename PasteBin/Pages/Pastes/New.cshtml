@page
@model PasteBin.Pages.Pastes.NewModel
@{
    ViewData["Title"] = "New Paste";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>New Paste</h1>
    <a asp-page="/Pastes/Index" class="btn btn-secondary">Back</a>
</div>

<form method="post">
    <div class="mb-3">
        <textarea name="content" class="form-control font-monospace" rows="20" placeholder="Paste your content here..." autofocus></textarea>
    </div>
    <button type="submit" class="btn btn-secondary">Save</button>
</form>